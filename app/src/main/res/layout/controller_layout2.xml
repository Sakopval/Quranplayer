<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.google.android.material.button.MaterialButton
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/Widget.Material3.Button.IconButton"
        app:icon="@drawable/play"
        app:iconTint="#000000"
        android:layout_below="@+id/timeLine"
        android:layout_centerHorizontal="true"
        android:id="@+id/play"/>
    <com.google.android.material.button.MaterialButton
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/Widget.Material3.Button.IconButton"
        app:icon="@drawable/history"
        app:iconTint="#000000"
        android:layout_alignParentEnd="true"
        android:id="@+id/history"/>
    <com.google.android.material.button.MaterialButton
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/Widget.Material3.Button.IconButton"
        app:icon="@drawable/avd_anim"
        app:iconTint="#000000"
        android:layout_alignParentStart="true"
        android:id="@+id/sessionStart"/>
    <com.google.android.material.button.MaterialButton
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/Widget.Material3.Button.IconButton"
        app:icon="@drawable/seek_forward"
        app:iconTint="#000000"
        android:layout_below="@+id/timeLine"
        android:layout_toEndOf="@+id/play"
        android:layout_marginStart="20dp"
        android:id="@+id/seekForward"/>
    <com.google.android.material.button.MaterialButton
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/Widget.Material3.Button.IconButton"
        app:icon="@drawable/seek_back"
        app:iconTint="#000000"
        android:layout_toStartOf="@+id/play"
        android:layout_below="@+id/timeLine"
        android:layout_marginEnd="20dp"
        android:id="@+id/seekBac"/>
    <androidx.media3.ui.DefaultTimeBar
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:scrubber_color="#000000"
        app:played_color="#000000"
        android:layout_toEndOf="@+id/timePassed"
        app:unplayed_color="#94737171"
        android:layout_below="@+id/history"
        android:layout_toStartOf="@+id/totalTime"
        android:id="@+id/timeLine"/>
    <com.google.android.material.button.MaterialButton
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/Widget.Material3.Button.IconButton"
        app:icon="@drawable/volume_max"
        app:iconTint="#000000"
        android:layout_below="@+id/timeLine"
        android:id="@+id/volMax"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/totalTime"
        android:layout_alignParentEnd="true"
        android:layout_above="@+id/play"
        android:textColor="#000000"
        android:layout_marginEnd="5dp"
        android:text="255"
        android:layout_marginBottom="5dp"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/timePassed"
        android:layout_alignParentStart="true"
        android:layout_above="@+id/play"
        android:textColor="#000000"
        android:layout_marginStart="5dp"
        android:text="255"
        android:layout_marginBottom="5dp"/>
    <com.google.android.material.button.MaterialButton
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/Widget.Material3.Button.IconButton"
        app:icon="@drawable/save"
        app:iconTint="#000000"
        android:layout_below="@+id/timeLine"
        android:layout_alignParentEnd="true"
        android:id="@+id/saveBut"/>

</RelativeLayout>